# =============================================================================
# MediGraph AI — environment template
# =============================================================================
# Copy to `.env` and fill in ONLY the integrations you want to enable.
# With NO .env at all, the platform runs fully offline (bundled synthetic data,
# embedded graph, deterministic planner) — no credentials required.
#
# NEVER commit a real .env. It is gitignored for a reason.
# =============================================================================

# ---- Branding ----
MEDIGRAPH_ORG="Demo Health System"

# ---- Graph backend: "embedded" (default, offline) or "neo4j" (live) ----
MEDIGRAPH_GRAPH_BACKEND=embedded
# NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# ---- LLM provider: "mock" (default, offline) or "openai" (live) ----
MEDIGRAPH_LLM_PROVIDER=mock
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ---- Snowflake (optional warehouse source-of-truth) ----
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=
# SNOWFLAKE_ROLE=

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
MEDIGRAPH_SECRET_KEY=dev-insecure-change-me
MEDIGRAPH_TOKEN_TTL_MIN=480

# ---- Synthetic data (offline mode) ----
MEDIGRAPH_SYNTH_PATIENTS=120
MEDIGRAPH_SYNTH_SEED=42
